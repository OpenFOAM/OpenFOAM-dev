FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [velocity];

omega           60 [rpm];

internalField
{
    type            coded;

    evaluate
    #{
        const dimensionedVector omega =
            $<dimensionedScalar>omega*vector(0, 0, 1);

        const dimensionedVector O(dimensions::length, field.mesh().bounds().midpoint());

        field = omega^(C - O);
    #};
}

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    ".*"
    {
        type            calculated;
        value           uniform (0 0 0);
    }
}


