EXE_INC = \
    $(shell \
        $(WM_PROJECT_DIR)/bin/tools/foamVersionCompare \
        $(ParaView_VERSION) ge 6.1.0 && \
        echo "--std=c++17" \
    ) \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/parallel/parallel/lnInclude \
    -I$(LIB_SRC)/polyTopoChange/lnInclude \
    -I$(LIB_SRC)/tracking/lnInclude \
    -I$(LIB_SRC)/lagrangian/basic/lnInclude \
    -I$(LIB_SRC)/Lagrangian/Lagrangian/lnInclude \
    -I../PVFoamReader/vtk \
    -I$(VTK_INCLUDE_DIR) \
    -I$(ParaView_INCLUDE_DIR) \
    -I$(ParaView_INCLUDE_DIR)/vtkkwiml \
    $(shell \
        test -f $(VTK_INCLUDE_DIR)/vtkPolyhedron.h && \
        echo "-DHAS_VTK_POLYHEDRON" || \
        echo "-UHAS_VTK_POLYHEDRON" \
    )

LIB_LIBS = \
    -lfiniteVolume \
    -lmeshTools \
    -lparallel \
    -lpolyTopoChange \
    -lgenericFvFields \
    -lgenericLagrangianFields \
    -llagrangian \
    -lLagrangian \
    -L$(FOAM_LIBBIN) \
    $(GLIBS)
