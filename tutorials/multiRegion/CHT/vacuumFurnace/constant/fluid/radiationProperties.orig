FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/fluid";
    object      radiationProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

radiationModel  fvDOM;

fvDOM
{
    nPhi        3;
    nTheta      3;
    tolerance   1e-3;
    maxIter     10;
}

solverFreq 1;

absorptionEmissionModel constant;

constant
{
    absorptivity    0;
    emissivity      0;
    E               0;
}

scatterModel    none;

sootModel       none;

// ************************************************************************* //
