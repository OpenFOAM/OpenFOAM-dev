FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "templates/0/fluid";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

Uinlet          10;

dimensions      [velocity];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            flowRateInletVelocity;
        meanVelocity    constant $Uinlet;
        value           uniform (0 0 0);
    }

    outlet
    {
        type            pressureInletOutletVelocity;
    }

    wall
    {
        type            noSlip;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}


