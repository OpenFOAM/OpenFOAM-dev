FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/solid";
    object      phi;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 2 -3 0 0 -1 0];

internalField   uniform 0;

boundaryField
{
    positive
    {
        type            fixedValue;
        value           uniform -0.05;
    }

    negative
    {
        type            fixedValue;
        value           uniform 0.05;
    }

    "(electrode_on_nonCoupleElectrode|wire_on_nonCoupleWire)"
    {
        type            zeroGradient;
        value           $internalField;
    }

    "nonCouple.*"
    {
        type            zeroGradient;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

