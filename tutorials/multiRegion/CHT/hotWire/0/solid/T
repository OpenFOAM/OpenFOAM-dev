FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/solid";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 0 0 1 0 0 0 ];

internalField   uniform 297;

boundaryField
{
    positive
    {
        type            fixedValue;
        value           $internalField;
    }

    negative
    {
        type            fixedValue;
        value           $internalField;
    }

    "(electrode_on_nonCoupleElectrode|wire_on_nonCoupleWire)"
    {
        type            coupledTemperature;
        value           $internalField;
    }

    "nonCouple.*"
    {
        type            zeroGradient;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

