FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/fluid";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.0024;

boundaryField
{
    inlet
    {
        type            turbulentKineticEnergy;
        intensity       0.04;
        value           $internalField;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      $internalField;
    }

    wall
    {
        type            kqRWallFunction;
        value           $internalField;
    }

    "nonCouple.*"
    {
        type        zeroGradient;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}


