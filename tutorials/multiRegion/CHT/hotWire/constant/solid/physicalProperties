thermoType
{
    type            heSolidThermo;
    mixture         pureMixture;
    transport       constIsoSolid;
    thermo          eConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleInternalEnergy;
}

mixture
{
    specie
    {
        molWeight       26.982;
    }
    equationOfState
    {
        rho             2699;
    }
    thermodynamics
    {
        Cv              896.894;
        hf              0;
    }
    transport
    {
        kappa           237;
    }
}

