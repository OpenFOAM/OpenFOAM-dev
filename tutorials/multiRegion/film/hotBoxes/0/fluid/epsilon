FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/fluid";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [turbulentEpsilon];

internalField   uniform 1e-7;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    sides
    {
        type            epsilonWallFunction;
        value           uniform 1e-7;
    }

    film
    {
        type            epsilonWallFunction;
        value           uniform 1e-7;
    }
}

