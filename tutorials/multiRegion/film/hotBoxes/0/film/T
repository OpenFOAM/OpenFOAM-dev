FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/film";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [temperature];

internalField   uniform 300;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    surface
    {
        type            coupledTemperature;
        value           $internalField;
    }

    wall
    {
        type            fixedValue;
        value           uniform 350;
    }

    sides
    {
        type            zeroGradient;
    }
}

