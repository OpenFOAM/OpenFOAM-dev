FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField
{
    type        zonal;

    defaultValue    1 [bar];

    zones
    {
        lowPressure
        {
            type            box;

            box             (0 -1 -1) (5 1 1);

            value           0.1 [bar];
        }
    }
}

boundaryField
{
    sides
    {
        type            zeroGradient;
    }

    empty
    {
        type            empty;
    }
}

