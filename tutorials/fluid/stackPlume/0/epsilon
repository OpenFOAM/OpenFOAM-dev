FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

epsilonStack 6.16;

dimensions      [turbulentEpsilon];

internalField
{
    type            atmosphericBoundaryLayerTurbulentEpsilon;
    libs            ("libatmosphericModels.so");
}

boundaryField
{
    inletWind
    {
        $internalField;
    }

    inlet
    {
        type            turbulentEpsilon;
        mixingLength    0.049; // 7% of diameter
        value           uniform $epsilonStack;
    }

    outlet
    {
        type            atmosphericBoundaryLayerTurbulentEpsilon;
        libs            ("libatmosphericModels.so");
    }

    wall
    {
        type            epsilonWallFunction;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

