FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [turbulentViscosity];

internalField   uniform 0;

boundaryField
{
    ".*"
    {
        type            calculated;
        value           uniform 0;
    }

    wall
    {
        type            nutAtmosphericBoundaryLayerWallFunction;
        libs            ("libatmosphericModels.so");
        value           uniform 0;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

