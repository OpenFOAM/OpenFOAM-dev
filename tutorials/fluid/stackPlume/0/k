FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

kStack 1.5;

dimensions      [turbulentKineticEnergy];

internalField
{
    type            atmosphericBoundaryLayerTurbulentKineticEnergy;
    libs            ("libatmosphericModels.so");
}

boundaryField
{
    inletWind
    {
        $internalField;
    }

    inlet
    {
        type            turbulentKineticEnergy;
        intensity       0.05;
        value           uniform $kStack;
    }

    outlet
    {
        $internalField;
    }

    wall
    {
        type            kqRWallFunction;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

