FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [velocity];

internalField   uniform (0 0 0);

boundaryField
{
    movingWall
    {
        type            fixedValue;
        // Field Value
        value           uniform (1 0 0);
    }

    fixedWalls
    {
        type            fixedValue;
        // Field Value
        value           uniform (0 0 0);
    }

    frontAndBack
    {
        type            empty;
    }
}

