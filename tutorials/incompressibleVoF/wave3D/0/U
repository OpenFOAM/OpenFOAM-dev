FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [velocity];

internalField
{
    type        waveVelocity;
    libs        ("libwaves.so");
}

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    "(inlet|inletSide)"
    {
        type            waveVelocity;
        libs            ("libwaves.so");
    }

    top
    {
        type            pressureInletOutletVelocity;
    }

    bottom
    {
        type            noSlip;
    }
}


