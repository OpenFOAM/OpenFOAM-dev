FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alpha.water;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [];

internalField
{
    type        zonal;

    defaultValue    0;

    zones
    {
        water
        {
            type            box;

            box             (-100 -100 -100) (100 100 0);

            value           1;
        }
    }
}

boundaryField
{
    front
    {
        type            empty;
    }

    back
    {
        type            empty;
    }

    walls
    {
        type            zeroGradient;
    }
}

// ************************************************************************* //
