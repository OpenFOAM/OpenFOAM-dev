FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

mover
{
    type            list;

    libs            ("libfvMotionSolvers.so");

    rotor
    {
        type            solidBody;

        cellZone        rotor;

        solidBodyMotionFunction
        {
            type          rotatingMotion;

            origin        (0 0 0);
            axis          (0 0 1);

            omega         60 [rpm];
        }
    }

    stator
    {
        type            solidBody;

        cellZone        stator;

        solidBodyMotionFunction
        {
            type          rotatingMotion;

            origin        (0 0 0);
            axis          (0 0 -1);

            omega         60 [rpm];
        }
    }
}


