FoamFile
{
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField
{
    type        zonal;

    defaultValue    (-1.5 0 0);

    zones
    {
        burnt
        {
            type            box;

            box             (0 -1 -1) (0.025 1 1);

            value           (-10 0 0);
        }
    }
}

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (-1.5 0 0);
    }

    outlet
    {
        type            zeroGradient;
    }

    sides
    {
        type            empty;
    }
}

