FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default             none;

    div(phi,U)          Gauss upwind;

    div(phi,b)          Gauss vanAlbada01;
    div(phiXi,Xi)       Gauss limitedVanAlbada 1 10;

    div(phib,fu.u)      Gauss vanAlbada01;
    div(phib,egr.u)     Gauss vanAlbada01;
    div(phib,h.u)       Gauss vanAlbada;
    div(phib,K)         Gauss vanAlbada;

    div(phic,ft.b)      Gauss vanAlbada01;
    div(phic,h.b)       Gauss vanAlbada;
    div(phic,K)         Gauss vanAlbada;

    div(phi,(p|rho))    Gauss vanAlbada;
    div(meshPhi,p)      Gauss vanAlbada;

    div(phi,k)          Gauss vanAlbada;
    div(phi,epsilon)    Gauss vanAlbada;

    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear limited corrected 0.333;
    laplacian(Db,b) Gauss linear limited corrected 0.1;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         limited corrected 0.333;
}


