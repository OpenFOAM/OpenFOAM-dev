FoamFile
{
    format      ascii;
    class       volScalarField;
    object      egr;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [];

internalField
{
    type        zonal;

    defaultValue    0;

    fuelAir
    {
        burnt
        {
            type            box;

            box             (0 0 -1) (1 0.01 1);

            value           0.01;
        }
    }
}

boundaryField
{
    left
    {
        type            symmetryPlane;
    }

    right
    {
        type            symmetryPlane;
    }

    top
    {
        type            symmetryPlane;
    }

    bottom
    {
        type            symmetryPlane;
    }

    frontAndBack
    {
        type            empty;
    }
}

// ************************************************************************* //
