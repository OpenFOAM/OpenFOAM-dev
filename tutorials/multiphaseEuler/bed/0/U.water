FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U.water;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [velocity];

internalField   uniform (0 0 0);

boundaryField
{
    top
    {
        type            pressureInletOutletVelocity;
        phi             phi.water;
    }
    walls
    {
        type            noSlip;
    }
}

sources
{
    massSource
    {
        type            uniformInletOutlet;
        uniformInletValue (0 0 0);
    }
}

// ************************************************************************* //
