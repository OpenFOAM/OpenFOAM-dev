FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alpha.solid;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField
{
    type        zonal;

    defaultValue    0;

    zones
    {
        dryer
        {
            type            lookup;
            value           0.2;
        }
    }
}

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"(internalField = uniform 0)

    inlet
    {
        type            fixedValue;
        value           uniform 0;
    }

    outlet
    {
        type            zeroGradient;
    }

    wall
    {
        type            zeroGradient;
    }
}


// ************************************************************************* //
