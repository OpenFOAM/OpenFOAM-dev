FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [turbulentKineticEnergy];

internalField
{
    type            atmosphericBoundaryLayerTurbulentKineticEnergy;
    libs            ("libatmosphericModels.so");
}

boundaryField
{
    outlet
    {
        $internalField;
    }

    inlet
    {
        $internalField;
    }

    terrain
    {
        type            kqRWallFunction;
        value           uniform 0;
    }

    ground
    {
        type            zeroGradient;
    }

    #include "include/sideAndTopPatches"
}


