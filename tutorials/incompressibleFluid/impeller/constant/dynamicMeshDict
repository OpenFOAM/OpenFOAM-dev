FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

mover
{
    type            solidBody;

    libs            ("libpointMeshMovers.so");

    cellZone        rotating;

    solidBodyMotionFunction
    {
        type          rotatingMotion;

        origin        (0 0 0);
        axis          (1 0 0);

        omega         60 [rpm];
    }
}


