FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [velocity];

internalField   uniform (1 0 0);

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    rotor
    {
        type            MRFnoSlip;
    }

    freestream
    {
        type                MRFFreestreamVelocity;
        freestreamValue0    (1 0 0);
        freestreamValue     $internalField;
    }
}

