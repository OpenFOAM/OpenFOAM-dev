FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

mover
{
    type            solidBody;

    libs            ("libpointMeshMovers.so");

    cellZone        ball;

    solidBodyMotionFunction
    {
        type            oscillatingRotatingMotion;

        origin          (0 0 0);
        amplitude       (0 0 45);
        omega           6.283185307179586;
    }
}


