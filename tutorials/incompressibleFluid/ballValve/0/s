FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      s;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [];

internalField   uniform 0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    inlet
    {
        type            functionalFixedValue;

        function
        {
            type    zonal;

            defaultValue    0;

            zones
            {
                inlet
                {
                    type        cylinder;

                    point1      (-0.51 0 0);
                    point2      (-0.49 0 0);
                    radius      0.05;

                    zone
                    {
                        type        patch;
                        patch       inlet;
                    }

                    value       1;
                }
            }
        }
    }

    lowerOutlet
    {
        type            inletOutlet;
        inletValue      uniform 0;
    }

    upperOutlet
    {
        type            inletOutlet;
        inletValue      uniform 0;
    }

    wall
    {
        type            zeroGradient;
    }
}


