FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [temperature];

internalField
{
    type        surfaces;

    defaultValue 300;

    surfaces
    {
        bubble
        {
            type        sphere;

            centre      (0.5 0.5 0.5);
            radius      0.1;

            value       578;
        }
    }
}

boundaryField
{
    walls
    {
        type            zeroGradient;
    }

    defaultFaces
    {
        type            empty;
    }
}

