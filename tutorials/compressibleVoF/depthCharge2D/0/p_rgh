FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [pressure];

internalField
{
    type        surfaces;

    defaultValue 1e5;

    surfaces
    {
        bubble
        {
            type        cylinder;

            point1      (0.5 0.5 -1);
            point2      (0.5 0.5 1);
            radius      0.1;

            value       1e6;
        }
    }
}

boundaryField
{
    walls
    {
        type            fixedFluxPressure;
    }

    defaultFaces
    {
        type            empty;
    }
}

