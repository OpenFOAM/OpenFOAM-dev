FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      functions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

cloudMass
{
    type        cloudMass;
    libs        ("libLagrangianCloudFunctionObjects.so");
    cloud       cloud;
    writeControl writeTime;
}

cloudTotalMass
{
    type        LagrangianFieldValue;
    libs        ("libLagrangianFunctionObjects.so");
    Lagrangian  cloud;
    operation   sum;
    field       m;
    weightField number;
}

cloudMassFlux
{
    type        cloudMassFlux;
    libs        ("libLagrangianCloudFunctionObjects.so");
    cloud       cloud;
}

#includeFunc patchFlowRate
(
    patch=atmosphere,
    cloud:phim,
    name=cloudAtmosphereMassFlowRate
)

#includeFunc cellSum
(
    cloud:rhoEqn.water:Su,
    name=cloudMassTransfer
)

#includeFunc timeStep

