FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system/Lagrangian/cloud";
    object      LagrangianSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

tracking    linear;

ddtSchemes
{
    default     Euler;
}

SpSchemes
{
    default     none;
    Sp(D,U)     implicit;
    Sp(D,Uc)    implicit;
}

averagingSchemes
{}

interpolationSchemes
{
    default     cell;
    alphac.air  cellPoint;
    Uc          cellPoint;
}

accumulationSchemes
{
    S(m)        cell;
    S(m*U)      cell;
    S(m*e)      cell;
}


