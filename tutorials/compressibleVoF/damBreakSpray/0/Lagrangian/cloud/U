FoamFile
{
    format      ascii;
    class       LagrangianVectorField;
    location    "0/Lagrangian/cloud";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [velocity];

internalField   uniform (0 0 0);

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    ".*"
    {
        type            escapeVelocity;
    }

    wall
    {
        type            reboundVelocity;
        e               1;
        mu              0;
    }
}

sources
{
    inlet
    {
        type            fanVelocity;
        normal          (0 0 1);
        thetaInner      0;
        thetaOuter      45 [deg];
        Ucentre         (1 1 0);
    }
}

