FoamFile
{
    format      ascii;
    class       LagrangianScalarField;
    location    "0/Lagrangian/cloud";
    object      m;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 0 0 0 0 0 0];

internalField   nonuniform List<scalar> 0();

boundaryField
{
    leftWall
    {
        type            calculated;
    }
    rightWall
    {
        type            calculated;
    }
    lowerWall
    {
        type            calculated;
    }
    atmosphere
    {
        type            calculated;
    }
    defaultFaces
    {
        type            empty;
    }
}

sources
{
    inlet
    {
        type            mass;
    }
}


