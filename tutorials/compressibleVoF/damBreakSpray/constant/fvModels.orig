FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      fvModels;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

cloud
{
    type            parcelCloud;
    libs            ("libLagrangianCloud.so");

    carrierPhase    air;
    phase           water;
}


