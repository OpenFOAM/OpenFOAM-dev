FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/Lagrangian/cloud";
    object      LagrangianModels;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

inlet
{
    type        pointInjection;
    point       (0.08 0.5 0.0073);
    numberRate  10000;
}

drag
{
    type        SchillerNaumannDrag;
}

gravity
{
    type        gravity;
}

collisionPhaseTransfer
{
    type        collisionPhaseTransfer;

    minFraction 10 [%]; // <-- only needed for parcel clouds
}

