FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alpha.air;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [];

internalField
{
    type        zonal;

    defaultValue    1;

    zones
    {
        water
        {
            type        box;
            box         (0 0 -1) (1 1 1);
            value       0;
        }

        oil
        {
            type        box;
            box         (0 -1 -1) (1 0 1);
            value       0;
        }

        mercury
        {
            type        box;
            box         (-1 -1 -1) (0 0 1);
            value       0;
        }
    }
}

boundaryField
{
    rotor
    {
        type            zeroGradient;
    }

    stator
    {
        type            zeroGradient;
    }

    front
    {
        type            empty;
    }

    back
    {
        type            empty;
    }
}

// ************************************************************************* //
