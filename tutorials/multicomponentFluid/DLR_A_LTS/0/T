FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField
{
    type        zonal;

    defaultValue    292;

    zones
    {
        fuel
        {
            type            box;
            box             (0.002 -0.01 0.005) (0.02 0.01 0.055);
            value           2200;
        }
    }
}

boundaryField
{
    inletfuel
    {
        type            fixedValue;
        value           uniform 292;
    }

    inletair
    {
        type            fixedValue;
        value           uniform 292;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform 292;
    }

    axis
    {
        type            empty;
    }

    leftside
    {
        type            zeroGradient;
    }

    burnerwall
    {
        type            zeroGradient;
    }

    burnertip
    {
        type            zeroGradient;
    }

    front
    {
        type            wedge;
    }

    back
    {
        type            wedge;
    }
}


