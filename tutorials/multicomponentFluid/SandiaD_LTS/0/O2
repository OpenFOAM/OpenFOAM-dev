FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      O2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [];

internalField
{
    type        zonal;

    defaultValue    0.23;

    zones
    {
        fuel
        {
            type            box;
            box             (0 -10 -100) (0.0036 10 0);
            value           0.1966;
        }
    }
}

boundaryField
{
    inletCH4
    {
        type            fixedValue;
        value           uniform 0.1966;
    }

    wallOutside
    {
        type            zeroGradient;
    }

    wallTube
    {
        type            zeroGradient;
    }

    inletPilot
    {
        type            fixedValue;
        value           uniform 0.054;
    }

    inletAir
    {
        type            fixedValue;
        value           uniform 0.23;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform 0.23;
    }

    frontAndBack_pos
    {
        type            wedge;
    }

    frontAndBack_neg
    {
        type            wedge;
    }
}


