FoamFile
{
    format      ascii;
    class       dictionary;
    location    "templates/materials/air";
    object      radiationProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

radiationModel  none; // P1, fvDOM;

solverFreq 10;

absorptionEmissionModel constant;

constant
{
    absorptivity    0.5;
    emissivity      0.5;
    E               0;
}

fvDOM
{
    nPhi        3;
    nTheta      3;
    tolerance   1e-3;
    maxIter     10;
}

scatterModel    none;

sootModel       none;

