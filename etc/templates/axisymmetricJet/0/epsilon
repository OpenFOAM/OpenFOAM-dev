FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

epsilonInlet      0.002;

dimensions      [turbulentEpsilon];

internalField   uniform $epsilonInlet;

boundaryField
{
    "(inlet|atmosphere)"
    {
        type            turbulentEpsilon;
        mixingLength    0.1;
        value           uniform $epsilonInlet;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

