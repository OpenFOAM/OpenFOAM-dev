FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [temperature];

internalField   uniform 300;

boundaryField
{
    <patchName>
    {
        type            fixedValue;
        value           uniform 400;
    }

    wall
    {
        type            fixedValue;
        value           $internalField;
    }
}

